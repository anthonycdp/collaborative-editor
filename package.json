{
  "name": "collaborative-editor",
  "version": "1.0.0",
  "description": "Real-time collaborative text editor with CRDT conflict resolution, offline sync, and presence indicators",
  "main": "dist/server/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "start": "node dist/server/index.js",
    "preview": "npm run build && npm run start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "collaborative-editing",
    "real-time",
    "crdt",
    "yjs",
    "websocket",
    "offline-first",
    "presence"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "yjs": "^13.6.19",
    "ws": "^8.18.0",
    "y-protocols": "^1.0.6",
    "y-indexeddb": "^9.0.12",
    "quill": "^2.0.3",
    "y-quill": "^1.0.0",
    "quill-cursors": "^4.0.2",
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "uuid": "^10.0.0",
    "lodash.debounce": "^4.0.8",
    "lib0": "^0.2.94"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/ws": "^8.5.13",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^10.0.0",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "tsx": "^4.19.2",
    "concurrently": "^9.1.2",
    "vitest": "^3.0.4",
    "@vitest/coverage-v8": "^3.0.4",
    "jsdom": "^26.0.0",
    "@testing-library/dom": "^10.4.0",
    "eslint": "^9.17.0",
    "typescript-eslint": "^8.19.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
